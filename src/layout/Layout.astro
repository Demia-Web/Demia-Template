---
import BaseHead from "../includes/BaseHead.astro";
import Header from "../includes/Header.astro";
import Footer from "../includes/Footer.astro";
import Menu from "../includes/Menu.astro";
import Grid from "@/components/dev/grid.astro";

const { title, description, keyword, theme = "light", dataPage } = Astro.props;
---

<!doctype html>
<html lang="it" id="html" data-theme={theme}>
  <head>
    <BaseHead title={title} description={description} keyword={keyword} />
    <slot name="head" />
  </head>
  <body id="body" class="relative">
    <Grid />
    <main data-barba="wrapper">
      <div data-barba="container" data-barba-namespace={dataPage} data-page={dataPage}>
        <Header />
        <Menu />
        <slot />
        <Footer />
      </div>
    </main>
    <script src="../libs/main.js"></script>
  </body>
</html>
